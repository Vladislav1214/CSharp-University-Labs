<Window x:Class="Lab_1.RegistrationCredentialsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab_1"
        mc:Ignorable="d"
        Title="Step 2: Create Credentials" Height="550" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <StackPanel VerticalAlignment="Center" Margin="40">
        <TextBlock Text="Create Your Account" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30" TextWrapping="Wrap" TextAlignment="Center"/>

        <TextBlock Text="Username:" Margin="0,0,0,5"/>
        <TextBox x:Name="UsernameTextBox" LostFocus="TextBox_LostFocus" Margin="0,0,0,2"/>
        <Border Height="16">
            <TextBlock x:Name="UsernameErrorText" Foreground="Red" FontSize="8" Visibility="Collapsed"/>
        </Border>

        <TextBlock Text="Email:" Margin="0,0,0,5"/>
        <TextBox x:Name="EmailTextBox" LostFocus="TextBox_LostFocus" Margin="0,0,0,2"/>
        <Border Height="16">
            <TextBlock x:Name="EmailErrorText" Foreground="Red" FontSize="8" Visibility="Collapsed"/>
        </Border>

        <TextBlock Text="Password:" Margin="0,0,0,5"/>
        <PasswordBox x:Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged" Margin="0,0,0,2"/>
        <Border Height="16">
            <TextBlock x:Name="PasswordErrorText" Foreground="Red" FontSize="8" Visibility="Collapsed"/>
        </Border>

        <TextBlock Text="Confirm Password:" Margin="0,0,0,5"/>
        <PasswordBox x:Name="ConfirmPasswordBox" PasswordChanged="PasswordBox_PasswordChanged" Margin="0,0,0,2"/>
        <Border Margin="0,0,0,30" Height="16">
            <TextBlock x:Name="ConfirmPasswordErrorText" Foreground="Red" FontSize="8" Visibility="Collapsed"/>
        </Border>

        <Button x:Name="FinalRegisterButton"  Content="COMPLETE REGISTRATION" Height="50" FontSize="16" FontWeight="Bold" Foreground="White" Cursor="Hand" Click="FinalRegisterButton_Click">
            <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4A90E2" Offset="0.0" />
                    <GradientStop Color="#50E3C2" Offset="1.0" />
                </LinearGradientBrush>
            </Button.Background>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </StackPanel>
</Window>
