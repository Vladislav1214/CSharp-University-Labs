<Window x:Class="Lab_1.GoogleLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab_1"
        mc:Ignorable="d"
        Title="Sign in - Google Accounts" Height="500" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="White">

    <StackPanel Margin="40">
        <TextBlock Text="G o o g l e" FontSize="22" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,20,0,0"
                   Foreground="#4285F4"/>

        <TextBlock Text="Login" FontSize="24" HorizontalAlignment="Center" Margin="0,15,0,0"/>

        <TextBlock Text="Email" Margin="0,10,0,5" Foreground="#555"/>
        <TextBox x:Name="EmailTextBox" Padding="8" BorderBrush="LightGray" BorderThickness="1"/>
        <TextBlock x:Name="EmailErrorText" Foreground="Red" FontSize="12" Margin="0,2,0,0" Visibility="Collapsed"/>

        <TextBlock Text="Password" Margin="0,15,0,5" Foreground="#555"/>
        <PasswordBox x:Name="PasswordBox" Padding="8" BorderBrush="LightGray" BorderThickness="1"/>
        <TextBlock x:Name="PasswordErrorText" Foreground="Red" FontSize="12" Margin="0,2,0,0" Visibility="Collapsed"/>

        <Button x:Name="LoginButton" Content="Sign In (Emulation)" 
                Height="40" Margin="0,30,0,0"
                Background="#4285F4" Foreground="White"
                FontSize="14" FontWeight="SemiBold"
                Click="LoginButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        
    </StackPanel>
</Window>